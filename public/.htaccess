# ==========================================================
# Metz Nederland B.V. - Apache configuratie
# ==========================================================

# ----------------------------------------------------------
# SPA routing: alle niet-bestaande paden naar index.html
# ----------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forceer HTTPS
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Forceer www (optioneel — verwijder dit blok als je juist GEEN www wil)
  RewriteCond %{HTTP_HOST} ^metz-nederland\.nl$ [NC]
  RewriteRule ^ https://www.metz-nederland.nl%{REQUEST_URI} [L,R=301]

  # ----------------------------------------------------------
  # Legacy WordPress redirects (301 — voor SEO behoud)
  # ----------------------------------------------------------

  # Oude WordPress query-style URLs (?p=123, ?page_id=456) → homepage
  RewriteCond %{QUERY_STRING} ^p=[0-9]+ [OR]
  RewriteCond %{QUERY_STRING} ^page_id=[0-9]+
  RewriteRule ^$ /? [R=301,L]

  # WordPress feeds bestaan niet meer
  RewriteRule ^feed/?$ / [R=301,L]
  RewriteRule ^comments/feed/?$ / [R=301,L]
  RewriteRule ^(.+)/feed/?$ /$1 [R=301,L]

  # WordPress admin/login → homepage (security + voorkom 404)
  RewriteRule ^wp-admin/?.*$ / [R=301,L]
  RewriteRule ^wp-login\.php$ / [R=301,L]
  RewriteRule ^xmlrpc\.php$ / [R=301,L]

  # WordPress archives (categorieën, tags, auteurs, datum-archieven)
  RewriteRule ^category/.*$ / [R=301,L]
  RewriteRule ^tag/.*$ / [R=301,L]
  RewriteRule ^author/.*$ / [R=301,L]
  RewriteRule ^[0-9]{4}/[0-9]{2}/?.*$ / [R=301,L]

  # Legacy /werkwijze/ subpages → /werkwijze
  RewriteRule ^werkwijze/onderzoek-en-advies/?$ /werkwijze [R=301,L]
  RewriteRule ^werkwijze/de-uitvoering/?$ /werkwijze [R=301,L]
  RewriteRule ^werkwijze/het-eindrapport(-2)?/?$ /werkwijze [R=301,L]

  # Privacy policy: oude WP slug had "-2" suffix
  RewriteRule ^privacy-policy-2/?$ /privacy-policy [R=301,L]

  # Oude vacature-detailpagina's → /vacatures (we hebben geen detail-routes)
  RewriteRule ^vacatures/[^/]+/?$ /vacatures [R=301,L]

  # Trailing slash normaliseren (consistente URLs voor Google)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # ----------------------------------------------------------
  # SPA fallback: bestaande bestanden/mappen direct serveren,
  # rest naar index.html (React Router)
  # ----------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

# ----------------------------------------------------------
# Compressie
# ----------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/rss+xml image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ----------------------------------------------------------
# Browser caching
# ----------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — kort cachen zodat updates snel zichtbaar zijn
  ExpiresByType text/html "access plus 0 seconds"

  # Assets met hash in bestandsnaam (CRA build) — lang cachen
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"

  # Afbeeldingen
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/gif "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # PDF
  ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# ----------------------------------------------------------
# Security headers
# ----------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # HSTS — alleen aanzetten als je 100% zeker bent dat https werkt
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ----------------------------------------------------------
# Bescherm gevoelige bestanden
# ----------------------------------------------------------
<FilesMatch "(^\.|\.(env|md|json|lock|log|gitignore)$)">
  Require all denied
</FilesMatch>

# index.html en asset-manifest.json zijn wel nodig
<Files "index.html">
  Require all granted
</Files>

# Custom error page (valt terug op SPA-rewrite)
ErrorDocument 404 /index.html
